# AXIOM Configuration
APP_NAME=AXIOM
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./axiom.db

# ChromaDB (Phase 3)
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_COLLECTION=axiom_memory

# Redis (Phase 3)
REDIS_URL=redis://localhost:6379

# LLM — Default: Local Ollama
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# Embedding Model
EMBEDDING_MODEL=nomic-embed-text

# Agent Settings
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=30
MAX_PARALLEL_AGENTS=5

# Self-Improvement
PREDICTION_SCORE_DELAY_HOURS=24
MIN_ACCURACY_THRESHOLD=0.55

# Market Data
YFINANCE_RATE_LIMIT_PER_MIN=60
NEWS_FETCH_INTERVAL_MINUTES=30
MARKET_SCAN_INTERVAL_MINUTES=15
