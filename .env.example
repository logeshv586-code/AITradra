# AXIOM V4 Unified Configuration

# Server & UI
HOST=0.0.0.0
PORT=8000
UI_BASE_URL=http://localhost:8000

# AXIOM V2.0 — NVIDIA NIM API Configuration
# Free inference at: https://build.nvidia.com
# Get key at:        https://build.nvidia.com/settings/api-keys
# API is OpenAI-compatible → base_url = https://integrate.api.nvidia.com/v1
# ─────────────────────────────────────────────────────────────

LLM_PROVIDER=nvidia_nim
# NVIDIA NIM PER-MODEL KEYS
MOONSHOT_API_KEY=your_nvidia_nim_key_here
NEMOTRON_API_KEY=your_nvidia_nim_key_here
MINIMAX_API_KEY=your_nvidia_nim_key_here
MISTRAL_API_KEY=your_nvidia_nim_key_here

# LOCAL LLM FALLBACK MODELS
LOCAL_REASONING_MODEL_PATH=NVIDIA-Nemotron-3-Nano-4B-Q4_K_M.gguf
LOCAL_GENERAL_MODEL_PATH=Qwen2.5-3B-Instruct-Q4_K_M.gguf
OLLAMA_URL=http://localhost:11434
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# RISK CONTROLS
PAPER_TRADE_MODE=true
MAX_POSITION_PCT=0.05
MAX_DAILY_LOSS_PCT=0.02
MAX_OPEN_POSITIONS=5
MIN_SIGNAL_CONFIDENCE=0.70
MIN_CONSENSUS_AGENTS=3

# SCHEDULER
NEWS_FETCH_INTERVAL_MIN=10
PRICE_FETCH_INTERVAL_MIN=5
RAG_REINDEX_INTERVAL_MIN=15

# Mission Control Automation
GITHUB_PAT=
GITHUB_REPO=logeshv586-code/AITradra
